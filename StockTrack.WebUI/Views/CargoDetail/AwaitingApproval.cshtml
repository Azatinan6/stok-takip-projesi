@using StockTrack.Dto.CargoDetail
@using StockTrack.WebUI.Enums
@model List<ResultAwitingApprovalDto>
@{
    ViewData["Title"] = "Onay Bekleyen Kargolar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex flex-wrap gap-3 mb-4">
    <a href="~/CargoDetail/Index" class="btn rounded-pill px-4 shadow-sm border" style="background-color: #f1f3f5; color: #495057;">Tümü (@ViewBag.AllCount)</a>
    <a href="~/CargoDetail/AwaitingApproval" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fde2e1; color: #d62828; border: 1px solid #f5c2c0;">Onay Bekliyor (@ViewBag.PendingCount)</a>
    <a href="~/CargoDetail/ReadyForCargo" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fff4cc; color: #e0a800; border: 1px solid #ffe69c;">Paketlendi (@ViewBag.PackagedCount)</a>
    <a href="~/CargoDetail/CargoInDelivery" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d0ebff; color: #1971c2; border: 1px solid #a5d8ff;">Kargoda (@ViewBag.InCargoCount)</a>
    <a href="~/CargoDetail/Delivered" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d3f9d8; color: #2b8a3e; border: 1px solid #b2f2bb;">Teslim Edildi (@ViewBag.DeliveredCount)</a>
    <a href="~/CargoDetail/Cancelled" class="btn rounded-pill px-4 shadow-sm" style="background-color: #ffe3e3; color: #c92a2a; border: 1px solid #ffc9c9;">İptal Edilenler (@ViewBag.CancelledCount)</a>
    <a href="~/CargoDetail/Deleted" class="btn rounded-pill px-4 shadow-sm" style="background-color: #e9ecef; color: #6c757d; border: 1px solid #dee2e6;">Silinenler (@ViewBag.DeletedCount)</a>
</div>

<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
    <h4>Onay Bekleyen Kargolar</h4>
</div>
<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>ID</th> 
            <th>Durum</th> 
            <th>Tarih</th> 
            <th>Kullanıcı</th> 
            <th>Depo</th> 
            <th>Ürün (Kategori : Miktar)</th> 
            <th>Lokasyon</th> 
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td><span class="badge bg-danger">@item.StatusName</span></td>
                <td>@(item.RequestFormRequestedDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                <td>@(item.RequestFormRequestedBy ?? "-")</td>
                <td>@item.MainRepoName</td>
                <td>
                    @foreach (var p in item.Products)
                    {
                        <div>@p.CategoryName : @p.Quantity Adet</div>
                    }
                </td>
                <td>@item.HospitalName</td>
                <td>
                    <button type="button" class="btn btn-sm btn-primary change-status-btn"
                            data-bs-toggle="modal" data-bs-target="#cargoStatusModal"
                            data-cargodetailid="@item.Id"
                            data-location="@item.HospitalName"
                            data-category="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.CategoryName)) : "-")"
                            data-product="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.ProductName)) : "-")"
                            data-quantity="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.Quantity)) : "-")"
                            data-receiver="@item.ReceiverFullName"
                            data-address="@item.HospitalAddress">
                        <i class="mdi mdi-cog"></i> İşlem Yap
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Kargo Durumu Modal -->
<div class="modal fade" id="cargoStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <form asp-action="SaveCargoInfo" id="cargoOperasyonForm" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="cargoDetailId" />

                <div class="modal-header bg-light">
                    <h5 class="modal-title text-primary"><i class="mdi mdi-check-circle-outline"></i> Onay İşlem Merkezi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="row"> 
                        <div class="col-lg-6 border-end pe-4">
                            <h6 class="text-uppercase text-muted mb-3 border-bottom pb-2">1. Gönderim Detayı</h6>
                            <table class="table table-sm table-borderless">
                                <tbody>
                                    <tr><td class="text-muted" style="width: 140px;">Lokasyon:</td><td class="fw-bold" id="summaryLocation">-</td></tr>
                                    <tr><td class="text-muted">Kategori:</td><td class="fw-bold" id="summaryCategory">-</td></tr>
                                    <tr><td class="text-muted">Ürün Adı:</td><td class="fw-bold"><span id="summaryProduct">-</span></td></tr>
                                    <tr><td class="text-muted">Adet:</td><td class="fw-bold" id="summaryQuantity">-</td></tr>
                                    <tr><td class="text-muted">Alıcı:</td><td class="fw-bold" id="summaryRecipient">-</td></tr>
                                    <tr><td class="text-muted">Adres:</td><td class="fw-bold small text-wrap" id="summaryAddress">-</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="col-lg-6 ps-4">
                            <h6 class="text-uppercase text-muted mb-3 border-bottom pb-2">2. Karar</h6>
                            <div class="mb-3">
                                <label class="form-label fw-bold">İşlem <span class="text-danger">*</span></label>
                                <select name="StatusId" id="cargoStatusSelect" class="form-select border-primary">
                                    <option value="">-- Seçiniz --</option>
                                    <option value="@((int)EnumStatusType.Paketlendi)">Onayla (Paketlendi)</option>
                                    <option value="@((int)EnumStatusType.İptal)">Reddet (İptal Et)</option>
                                </select>
                            </div>
                            <div id="cancelReasonField" class="d-none mt-3">
                                <label class="form-label text-danger fw-bold">İptal Sebebi <span class="text-danger">*</span></label>
                                <textarea name="CancelDescription" id="cancelReason" class="form-control border-danger" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>                    
                    <button type="button" id="btnSaveCargo" class="btn btn-success px-5">Kaydet ve Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ST_IPTAL = @((int)EnumStatusType.İptal);

        $("#cargoStatusSelect").on("change", function() {
            const st = parseInt($(this).val());
            $("#cancelReasonField").toggleClass("d-none", st !== ST_IPTAL);
        });

        $("#btnSaveCargo").on("click", function () {
            const st = parseInt($("#cargoStatusSelect").val());
            const reason = $("#cancelReason").val().trim();

            if (!st) {
                Swal.fire('Hata', 'Lütfen bir işlem seçin.', 'warning');
                return;
            }
            if (st === ST_IPTAL && !reason) {
                Swal.fire('Hata', 'İptal sebebi girmelisiniz.', 'warning');
                return;
            }
            $("#cargoOperasyonForm").submit();
        });

        $(document).on("click", ".change-status-btn", function () {
            const d = $(this).data();
            $("#cargoDetailId").val(d.cargodetailid);
            $("#summaryLocation").text(d.location);
            $("#summaryCategory").text(d.category);
            $("#summaryProduct").text(d.product);
            $("#summaryQuantity").text(d.quantity);
            $("#summaryRecipient").text(d.receiver);
            $("#summaryAddress").text(d.address);
            $("#cargoStatusSelect").val("").trigger("change");
        });
    </script>
}