@using StockTrack.Dto.CargoName
@model IEnumerable<CargoNameDeletedDto>

@{
    ViewData["Title"] = "Silinen Kargo İsimleri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4>Silinen Kargo İsimleri</h4>
<hr />

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>#Id</th>
            <th>Kargo Adı</th>
            <th>Silinme Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @{
            int count = 1;
        }
        @foreach (var cargoName in Model)
        {
            <tr>
                <td>@(count++)</td>
                <td>@cargoName.Name</td>
                <td>@cargoName.DeletedDate?.ToString("dd MMMM yyyy HH:mm")</td>
                <td>
                    <form asp-controller="CargoName" asp-action="Restore" asp-route-id="@cargoName.Id" method="post" onsubmit="return confirm('Bu kargo ismini geri yüklemek istediğinize emin misiniz?');">
                        <button type="submit" class="btn btn-success btn-sm">
                            <i class="mdi mdi-restore me-1"></i> Geri Yükle
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="CargoName" asp-action="Index" class="btn btn-secondary">
        <i class="fa fa-arrow-left"></i>Kargo Listesine Dön
    </a>
</div>