@using StockTrack.Dto.Inventory
@model InventoryDetailDto

@{
    ViewData["Title"] = "Ürün Stok Detayları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 mb-4 bg-primary text-white">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-1 text-white">@Model.Brand @Model.Model</h4>
            <p class="mb-0 opacity-75">Ürün Adı: @Model.ProductName</p>
        </div>
        <div class="text-end">
            <h3 class="mb-1 text-white">@Model.CurrentStock Adet</h3>
            @if (Model.IsArcBox)
            {
                <span class="badge bg-warning text-dark fs-6 mt-1 shadow-sm"><i class="mdi mdi-star"></i> Seri No Takipli (Arc Box)</span>
            }
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">

        <ul class="nav nav-tabs nav-tabs-custom nav-justified" role="tablist">
            <li class="nav-item">
                <a class="nav-link active fw-bold" data-bs-toggle="tab" href="#tab-stock" role="tab">
                    <i class="mdi mdi-cube-outline me-1"></i> Stok Durumu
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-success" data-bs-toggle="tab" href="#tab-inbound" role="tab">
                    <i class="mdi mdi-arrow-bottom-left-bold-outline me-1"></i> Giriş Hareketleri
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-danger" data-bs-toggle="tab" href="#tab-outbound" role="tab">
                    <i class="mdi mdi-arrow-top-right-bold-outline me-1"></i> Çıkış Hareketleri
                </a>
            </li>
        </ul>

        <div class="tab-content p-3 text-muted mt-2">

            <div class="tab-pane active" id="tab-stock" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-dark">Güncel Stok Dağılımı</h5>
                </div>

                @if (Model.IsArcBox)
                {
                    <div class="alert alert-info border-0 shadow-sm">
                        <i class="mdi mdi-information me-2"></i> Bu ürün bir <strong>Arc Box</strong> olduğu için her bir cihazın Seri Numarası (SN) ve MAC adresi ayrı satırlarda takip edilmektedir. Toplam: @Model.CurrentStock Adet
                    </div>

                    <div class="table-responsive">
                        <table id="table-arcbox" class="table table-hover align-middle mb-0 my-datatable">
                            <thead class="bg-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Depo</th>
                                    <th>Seri No</th>
                                    <th>ETH MAC</th>
                                    <th>WLAN MAC</th>
                                    <th>Ürün Durumu</th>
                                    <th>Görsel</th>
                                    <th>Açıklama</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int stockCounter = 1;
                                }
                                @foreach (var item in Model.SerialNumbers)
                                {
                                    <tr>
                                        <td>@(stockCounter++)</td>
                                        <td>@item.WarehouseName</td>
                                        <td class="fw-bold text-primary">@item.SerialNumber</td>
                                        <td>@item.EthMac</td>
                                        <td>@item.WlanMac</td>
                                        <td><span class="badge bg-secondary">@item.StatusName</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <a href="@item.ImageUrl" target="_blank" class="btn btn-sm btn-light border shadow-sm" title="Görseli büyük aç">
                                                    <i class="mdi mdi-image-outline text-info fs-5"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-light border opacity-50" title="Görsel Yüklenmemiş" disabled>
                                                    <i class="mdi mdi-image-off-outline text-muted fs-5"></i>
                                                </button>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)</td>
                                        <td>
                                            <button class="btn btn-sm btn-warning shadow-sm"
                                                    onclick="openArcBoxModal(@item.Id, '@item.SerialNumber', '@item.EthMac', '@item.WlanMac', '@item.Description')">
                                                <i class="mdi mdi-pencil"></i> Düzenle
                                            </button>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.SerialNumbers.Any())
                                {
                                    <tr><td colspan="9" class="text-center text-muted">Henüz seri numarası eklenmemiş.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-nowrap my-datatable">
                            <thead class="bg-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Depo</th>
                                    <th>Stok Adeti</th>
                                    <th>Ürün Durumu</th>
                                    <th>Açıklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td>@(ViewBag.MainWarehouseName ?? "-")</td>
                                    <td><span class="badge bg-primary fs-6">@Model.CurrentStock</span></td>
                                    <td>
                                        <span class="badge bg-secondary" style="cursor:pointer;" data-bs-toggle="tooltip" data-bs-placement="top" title="@Model.StatusDetailsText">
                                            <i class="mdi mdi-information-outline me-1"></i> Detaylı Bilgi
                                        </span>
                                    </td>
                                    <td class="text-muted">Seri numarası takibi olmayan standart ürün.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="tab-pane" id="tab-inbound" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-dark">Stok Giriş Geçmişi</h5>
                    <button class="btn btn-success btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#modalInbound">
                        <i class="mdi mdi-plus"></i> Stok Arttır
                    </button>
                </div>

                <div class="table-responsive">
                    <table id="table-inbound" class="table table-hover align-middle text-nowrap my-datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>ID</th>
                                <th>Giriş Tarihi-Saati</th>
                                <th>Lokasyon</th>
                                <th>Eski Stok Adeti</th>
                                <th>Yeni Stok Adeti</th>
                                @if (Model.IsArcBox)
                                {
                                    <th>Seri No</th>
                                    <th>ETH MAC</th>
                                    <th>WLAN MAC</th>
                                }
                                <th>Ürün Durumu</th>
                                <th>Giriş Durumu</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int inCount = 1;
                            }
                            @foreach (var item in Model.InboundMovements)
                            {
                                <tr>
                                    <td>@(inCount++)</td>
                                    <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@item.LocationName</td>
                                    <td>@item.OldStock</td>
                                    <td class="text-success fw-bold">@item.NewStock <small>(+@item.Quantity)</small></td>
                                    @if (Model.IsArcBox)
                                    {
                                        <td class="fw-bold text-primary">@item.SerialNumber</td>
                                        <td>@item.EthMac</td>
                                        <td>@item.WlanMac</td>
                                    }
                                    <td><span class="badge bg-info bg-opacity-10 text-info border border-info">@item.ProductStatusName</span></td>
                                    <td><span class="badge bg-success bg-opacity-10 text-success border border-success">@item.MovementStatusName</span></td>
                                    <td>@(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane" id="tab-outbound" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-dark">Stok Çıkış Geçmişi</h5>
                    <button class="btn btn-danger btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#modalOutbound">
                        <i class="mdi mdi-minus"></i> Stok Azalt
                    </button>
                </div>

                <div class="table-responsive">
                    <table id="table-outbound" class="table table-hover align-middle text-nowrap my-datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>ID</th>
                                <th>Çıkış Tarihi-Saati</th>
                                <th>Lokasyon</th>
                                <th>Eski Stok Adeti</th>
                                <th>Yeni Stok Adeti</th>
                                @if (Model.IsArcBox)
                                {
                                    <th>Seri No</th>
                                    <th>ETH MAC</th>
                                    <th>WLAN MAC</th>
                                }
                                <th>Ürün Durumu</th>
                                <th>Çıkış Durumu</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int outCount = 1;
                            }
                            @foreach (var item in Model.OutboundMovements)
                            {
                                <tr>
                                    <td>@(outCount++)</td>
                                    <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@item.LocationName</td>
                                    <td>@item.OldStock</td>
                                    <td class="text-danger fw-bold">@item.NewStock <small>(-@item.Quantity)</small></td>
                                    @if (Model.IsArcBox)
                                    {
                                        <td class="fw-bold text-primary">@item.SerialNumber</td>
                                        <td>@item.EthMac</td>
                                        <td>@item.WlanMac</td>
                                    }
                                    <td><span class="badge bg-secondary">@item.ProductStatusName</span></td>
                                    <td><span class="badge bg-danger bg-opacity-10 text-danger border border-danger">@item.MovementStatusName</span></td>
                                    <td>@(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="modalInbound" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title text-white"><i class="mdi mdi-plus-circle me-2"></i> Stok Girişi Yap</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formInbound" action="~/Inventory/AddStock" method="post">
                    <input type="hidden" name="ProductId" value="@Model.ProductId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">İşlem Türü / Giriş Nedeni</label>
                        <select class="form-select" name="MovementStatusId" asp-items="ViewBag.InboundReasons" required>
                            <option value="">-- Giriş Nedeni Seçiniz --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <span class="fw-bold text-dark"><i class="mdi mdi-cube me-1"></i> Güncel Stok Adedi:</span>
                        <span class="badge bg-dark fs-6">@Model.CurrentStock Adet</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold">Eklenecek Adet</label>
                            <input type="number" class="form-control text-success fw-bold" name="Quantity" min="1" value="1" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Ürün Durumu</label>
                            <select class="form-select" name="ProductStatusId" asp-items="ViewBag.ProductStatuses" required>
                                <option value="">-- Ürün Durumu Seçin --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama / Not</label>
                        <textarea class="form-control" name="Description" rows="2" placeholder="İrsaliye no veya özel notlar..."></textarea>
                    </div>

                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-success"><i class="mdi mdi-check"></i> Stoğa Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalOutbound" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title text-white"><i class="mdi mdi-minus-circle me-2"></i> Stok Çıkışı Yap</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formOutbound" action="~/Inventory/RemoveStock" method="post">
                    <input type="hidden" name="ProductId" value="@Model.ProductId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">İşlem Türü / Çıkış Nedeni</label>
                        <select class="form-select" name="MovementStatusId" asp-items="ViewBag.OutboundReasons" required>
                            <option value="">-- Çıkış Nedeni Seçiniz --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <span class="fw-bold text-dark"><i class="mdi mdi-cube me-1"></i> Güncel Stok Adedi:</span>
                        <span class="badge bg-dark fs-6">@Model.CurrentStock Adet</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold text-danger">Düşülecek Adet</label>
                            <input type="number" class="form-control text-danger fw-bold" name="Quantity" min="1" value="1" required />
                        </div>

                        <div class="col-6">
                            <label class="form-label fw-bold">Ürün Durumu</label>
                            <select class="form-select" name="ProductStatusId" asp-items="ViewBag.ProductStatuses" required>
                                <option value="">-- Çıkış Durumu Seçin --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama / Not</label>
                        <textarea class="form-control" name="Description" rows="2" placeholder="Hangi hastane veya proje için..."></textarea>
                    </div>

                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light me-2" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-danger"><i class="mdi mdi-check"></i> Stoktan Düş</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalArcBox" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="mdi mdi-barcode-scan me-2"></i> Cihaz Bilgilerini Güncelle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="~/Inventory/UpdateArcBoxDetails" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="id" id="editArcBoxId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Seri Numarası (SN)</label>
                        <input type="text" name="serialNumber" id="editSerialNumber" class="form-control" required />
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">ETH MAC</label>
                            <input type="text" name="ethMac" id="editEthMac" class="form-control" placeholder="00:00..." />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">WLAN MAC</label>
                            <input type="text" name="wlanMac" id="editWlanMac" class="form-control" placeholder="00:00..." />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea name="description" id="editDescription" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Kapat</button>
                    <button type="submit" class="btn btn-warning fw-bold">Bilgileri Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openArcBoxModal(id, sn, eth, wlan, desc) {
        document.getElementById('editArcBoxId').value = id;
        document.getElementById('editSerialNumber').value = (sn === '-' ? '' : sn);
        document.getElementById('editEthMac').value = (eth === '-' ? '' : eth);
        document.getElementById('editWlanMac').value = (wlan === '-' ? '' : wlan);
        document.getElementById('editDescription').value = (desc === '-' ? '' : desc);
        new bootstrap.Modal(document.getElementById('modalArcBox')).show();
    }

    $(document).ready(function () {
        // 1. Tooltipleri canlandır
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // 2. DataTables'ı İÇERİDE canlandırıyoruz
        $('.my-datatable').DataTable({
            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" },
            "pageLength": 10,
            "responsive": true,
            "ordering": true
        });
    });
</script>