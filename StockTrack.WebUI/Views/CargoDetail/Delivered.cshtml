@using StockTrack.Dto.CargoDetail
@model List<ResultCargoDeliveredDto>

@{
    ViewData["Title"] = "Teslim Edilen Kargolar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Üst Menü Linkleri (Aynı Kalıyor) -->
<div class="d-flex flex-wrap gap-3 mb-4">
    <a href="~/CargoDetail/Index" class="btn rounded-pill px-4 shadow-sm border" style="background-color: #f1f3f5; color: #495057;">Tümü (@ViewBag.AllCount)</a>
    <a href="~/CargoDetail/AwaitingApproval" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fde2e1; color: #d62828; border: 1px solid #f5c2c0;">Onay Bekliyor (@ViewBag.PendingCount)</a>
    <a href="~/CargoDetail/ReadyForCargo" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fff4cc; color: #e0a800; border: 1px solid #ffe69c;">Paketlendi (@ViewBag.PackagedCount)</a>
    <a href="~/CargoDetail/CargoInDelivery" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d0ebff; color: #1971c2; border: 1px solid #a5d8ff;">Kargoda (@ViewBag.InCargoCount)</a>
    <a href="~/CargoDetail/Delivered" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d3f9d8; color: #2b8a3e; border: 1px solid #b2f2bb;">Teslim Edildi (@ViewBag.DeliveredCount)</a>
    <a href="~/CargoDetail/Cancelled" class="btn rounded-pill px-4 shadow-sm" style="background-color: #ffe3e3; color: #c92a2a; border: 1px solid #ffc9c9;">İptal Edilenler (@ViewBag.CancelledCount)</a>
</div>

<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
    <h4>Teslimatı Tamamlanan Kargolar</h4>
</div>
<hr />

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>ID</th>
            <th>Durum</th>
            <th>Teslim Tarihi</th>
            <th>Alıcı</th>
            <th>Kargo Firması</th>
            <th>Ürünler</th>
            <th>Kargo Takip No</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td><span class="badge bg-success">@item.StatusName</span></td>
                <td>@(item.CompletedCargoDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                <td>@item.ReceiverFullName</td>
                <td>@item.CargoCompany</td>
                <td>
                    @foreach (var p in item.Products)
                    {
                        <div class="small">@p.CategoryName : @p.Quantity Adet</div>
                    }
                </td>
                <td>
                    @if (item.IsOfficeDelivery)
                    {
                        <span class="badge bg-secondary">Ofisten Teslim</span>
                    }
                    else
                    {
                        <span class="fw-bold text-primary">@(item.TrackingNumber ?? "-")</span>
                    }
                </td>
                <td>
                    <!-- Detay Butonu: Hiçbir input yok, sadece bilgi taşır -->
                    <button type="button" class="btn btn-sm btn-info detail-btn"
                            data-bs-toggle="modal" data-bs-target="#cargoDetailModal"
                            data-location="@item.HospitalName"
                            data-company="@item.CargoCompany"
                            data-tracking="@item.TrackingNumber"
                            data-completed="@item.CompletedCargoDate?.ToString("dd.MM.yyyy HH:mm")"
                            data-given="@item.CargoGivenDate?.ToString("dd.MM.yyyy")"
                            data-receiver="@item.ReceiverFullName"
                            data-products="@(string.Join(", ", item.Products.Select(x => x.CategoryName + " x" + x.Quantity)))">
                        <i class="mdi mdi-eye"></i> Detay
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Kargo Detay Modal (Dropdown YOK, Sadece Bilgi) -->
<div class="modal fade" id="cargoDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-top border-success border-4">
            <div class="modal-header bg-light">
                <h5 class="modal-title text-success"><i class="mdi mdi-check-decagram"></i> Teslimat Detayları</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body">
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Teslimat Tarihi:</span>
                        <span class="fw-bold" id="detCompleted">-</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Kargo Firması:</span>
                        <span class="fw-bold" id="detCompany">-</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Takip Numarası:</span>
                        <span class="fw-bold text-primary" id="detTracking">-</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Alıcı:</span>
                        <span class="fw-bold" id="detReceiver">-</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Kargoya Verilme:</span>
                        <span class="fw-bold" id="detGiven">-</span>
                    </div>
                    <div class="list-group-item">
                        <span class="text-muted d-block mb-1">Ürün Detayı:</span>
                        <span class="small fw-bold" id="detProducts">-</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on("click", ".detail-btn", function () {
            const d = $(this).data();
            
            $("#detCompleted").text(d.completed || "-");
            $("#detCompany").text(d.company || "-");
            $("#detTracking").text(d.tracking || "Ofisten Teslim");
            $("#detReceiver").text(d.receiver || "-");
            $("#detGiven").text(d.given || "-");
            $("#detProducts").text(d.products || "-");
        });
    </script>
}