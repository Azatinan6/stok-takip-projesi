@model List<StockTrack.Dto.Inventory.InventoryListDto>

@{
    ViewData["Title"] = "Silinen Ürünler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <h4 class="m-0 font-weight-bold text-danger"><i class="mdi mdi-delete-restore me-2"></i>Silinen Ürünler (Çöp Kutusu)</h4>
</div>


        <table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th>Görsel</th>
                    <th>Depo</th>
                    <th>Ürün / Model</th>
                    <th>Kategori</th>
                    <th>Stok</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)" 
                                 class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                        </td>
                        <td><span class="badge bg-light text-dark">@item.WarehouseName</span></td>
                        <td>
                            <div class="fw-bold">@item.ProductName</div>
                            <small class="text-muted">@item.Brand - @item.Model</small>
                        </td>
                        <td>@item.CategoryName</td>
                        <td><span class="badge bg-danger">@item.StockQuantity</span></td>
                        <td class="text-end">
                            <form action="/Inventory/Restore" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-outline-success btn-sm shadow-sm">
                                    <i class="mdi mdi-backup-restore me-1"></i> Geri Yükle
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">Çöp kutusu boş.</td>
                    </tr>
                }
            </tbody>
        </table>

<div class="mt-3 mb-3">
    <a asp-controller="Inventory" asp-action="Stock" class="btn btn-secondary">
        <i class="fa fa-arrow-left"></i>Güncel Stok Listesine Dön
    </a>
</div>
