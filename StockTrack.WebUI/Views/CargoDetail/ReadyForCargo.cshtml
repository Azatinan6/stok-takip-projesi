@model List<ResultCargoForReadyDto>

@{
    ViewData["Title"] = "Kargoya Hazır Ürünler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex flex-wrap gap-3 mb-4">

    <!-- Tümü -->
    <a href="~/CargoDetail/Index"
           class="btn rounded-pill px-4 shadow-sm border"
           style="background-color: #f1f3f5; color: #495057;">
        Tümü (@ViewBag.AllCount)
    </a>

    <!-- Onay Bekliyor -->
    <a href="~/CargoDetail/AwaitingApproval"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #fde2e1; color: #d62828; border: 1px solid #f5c2c0;">
        Onay Bekliyor (@ViewBag.PendingCount)
    </a>

    <!-- Paketlendi -->
    <a href="~/CargoDetail/ReadyForCargo"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #fff4cc; color: #e0a800; border: 1px solid #ffe69c;">
        Paketlendi (@ViewBag.PackagedCount)
    </a>

    <!-- Kargoda -->
    <a href="~/CargoDetail/CargoInDelivery"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #d0ebff; color: #1971c2; border: 1px solid #a5d8ff;">
        Kargoda (@ViewBag.InCargoCount)
    </a>

    <!-- Teslim Edildi -->
    <a href="~/CargoDetail/Delivered"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #d3f9d8; color: #2b8a3e; border: 1px solid #b2f2bb;">
        Teslim Edildi (@ViewBag.DeliveredCount)
    </a>

    <!-- İptal -->
    <a href="~/CargoDetail/Cancelled"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #ffe3e3; color: #c92a2a; border: 1px solid #ffc9c9;">
        İptal Edilenler (@ViewBag.CancelledCount)
    </a>

    <!-- Silinen -->
    <a href="~/CargoDetail/Deleted"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #e9ecef; color: #6c757d; border: 1px solid #dee2e6;">
        Silinenler (@ViewBag.DeletedCount)
    </a>

</div>


<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
    <h4>Kargoya Hazır (Paketlenmiş) Ürünler</h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>ID</th> <!-- PDF: ID -->
            <th>Durum</th> <!-- PDF: Durum -->
            <th>Tarih</th> <!-- PDF: Tarih -->
            <th>Kullanıcı</th> <!-- PDF: Kullanıcı -->
            <th>Depo</th> <!-- PDF: Depo -->
            <th>Ürün (Kategori : Miktar)</th> <!-- PDF: Ürün -->
            <th>Lokasyon</th> <!-- PDF: Lokasyon -->
            <th>Kargo Verilme Tarihi</th> <!-- PDF: Yeni Kolon -->
            <th>Kargo Takip No</th> <!-- PDF: Kritik Zeka Kolonu -->
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <span class="badge @(item.StatusId == 4 ? "bg-info" : "bg-primary")">
                        @item.StatusName
                    </span>
                </td>
                <td>@item.RequestFormRequestedDate?.ToString("dd.MM.yyyy")</td>
                <td>@(item.RequestFormRequestedBy ?? "-")</td>
                <td>@item.MainRepoName</td>
                <td>
                    <!-- PDF Formatı: Kategori : Miktar -->
                    @foreach (var p in item.Products)
                    {
                        <div>@p.CategoryName : @p.Quantity Adet</div>
                    }
                </td>
                <td>@item.HospitalName</td>
                
                <!-- Kargo Verilme Tarihi -->
                <td>@(item.CargoGivenDate?.ToString("dd.MM.yyyy") ?? "-")</td>

                <!-- TAKİP NO ZEKASI -->
                <td>
                    @if (item.IsOfficeDelivery && (item.StatusId == (int)EnumStatusType.Kargoda || item.StatusId == (int)EnumStatusType.Tamamlandı))
                    {
                        <!-- PDF Kuralı: Ofisten teslimse ve süreç tamamlanmışsa bu yazacak -->
                        <span class="badge bg-secondary">Ofisten Teslim Edildi</span>
                    }
                    else if (string.IsNullOrEmpty(item.TrackingNumber) && (item.StatusId == (int)EnumStatusType.Kargoda || item.StatusId == (int)EnumStatusType.Tamamlandı))
                    {
                        <!-- PDF Kuralı: Kargoya verildi/Teslim edildi ama numara yoksa kırmızı fontla uyar -->
                        <span class="text-danger fw-bold">Takip No Giriniz !</span>
                    }
                    else
                    {
                        <!-- Normal şartlarda takip numarasını yaz -->
                        @(string.IsNullOrEmpty(item.TrackingNumber) ? "-" : item.TrackingNumber)
                    }
                </td>

                <td>
                    <!-- Senin modal butonun aynen kalıyor, sadece "İşlem Yap" diyoruz -->
                    <button type="button" class="btn btn-sm btn-primary change-status-btn"
                            data-bs-toggle="modal"
                            style="white-space:nowrap !important;"
                            data-bs-target="#cargoStatusModal"
                            data-cargodetail-id="@item.Id">
                        <i class="mdi mdi-cog"></i> İşlem Yap
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Resim Önizleme Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid rounded" style="max-height:70vh;">
            </div>
        </div>
    </div>
</div>

<!-- Kargo Durumu Modal -->
<div class="modal fade" id="cargoStatusModal" tabindex="-1" aria-labelledby="cargoStatusLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveCargoInfo" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" id="cargoDetailId" />


                <div class="modal-header">
                    <h5 class="modal-title" id="cargoStatusLabel">Kargo Bilgileri ve Durum Güncelle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>

                <div class="modal-body">
                    <!-- Satır Özeti -->
                    <div class="border rounded p-3 mb-3 bg-light">
                        <div class="d-flex align-items-start gap-3">

                            <div class="flex-grow-1">
                                <div class="row g-2">


                                    <div class="col-md-12">
                                        <strong>Ürün Bilgileri:</strong>
                                        <ul class="mb-0">
                                            <li><strong>Kategori:</strong> <span id="summaryCategory">-</span></li>
                                            <li><strong>Ürün:</strong> <span id="summaryProduct">-</span></li>
                                            <li><strong>Adet:</strong> <span id="summaryQuantity">-</span></li>
                                        </ul>
                                    </div>

                                    <div class="col-12"><hr class="my-2" /></div>
                                    <div>
                                        <div class="col-md-6"><strong>Alıcı:</strong> <span id="summaryRecipient">-</span></div>

                                    </div>
                                    <div class="col-md-6"><strong>Lokasyon:</strong> <span id="summaryLocation">-</span></div>
                                    <div class="col-md-6"><strong>Teslimat Adresi:</strong> <div id="summaryAddress" class="text-break small">-</div></div>
                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="row g-3">
                        <!-- Kargo Durumu -->
                        <div class="col-md-6 d-flex align-items-center gap-2">
                            <label for="status" class="form-label mb-0">Kargo Durum <span class="text-danger">*</span></label>
                            <select name="StatusId" id="status" class="form-select" required style="width:200px; Top:30px">
                                <option value="">-- Seçiniz --</option>
                                <option value="@((int)EnumStatusType.Kargoda)">Kargoya Verildi</option>
                                <option value="@((int)EnumStatusType.İptal)">İptal Edildi</option>
                            </select>
                        </div>

                        <!-- Kargo firma & takip (duruma göre zorunlu) -->
                        <div id="cargoExtraFields" class="row g-3 d-none">
                            <div class="col-md-6 d-flex align-items-center gap-2">
                                <label for="cargoCompany" class="form-label mb-0">Kargo Firması <span class="text-danger">*</span></label>
                                <select name="CargoNameId" id="cargoCompany" class="form-select" asp-items="@(ViewBag.CargoNames)">
                                    <option value="">-- Seçiniz --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="trackingNumber" class="form-label">Kargo Takip Numarası <span class="text-danger">*</span></label>
                                <input type="text" name="TrackingNumber" id="trackingNumber" class="form-control" maxlength="100" />
                            </div>
                        </div>
                        <!-- Ek alan (İptal Edildi ise) -->
                        <div id="cancelReasonField" class="row g-3 d-none">
                            <div class="col-md-12">
                                <label class="form-label">İptal Sebebi <span class="text-danger">*</span></label>
                                <textarea name="CancelDescription" id="cancelReason" class="form-control" rows="3" maxlength="500"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer d-flex justify-content-end">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="mdi mdi-content-save"></i> Kaydet
                        </button>
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Kapat
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Resim önizleme
        $(document).on("click", ".preview-img", function () {
            const imgSrc = $(this).data("img");
            const imgAlt = $(this).data("alt") || "";
            $("#modalImage").attr({ src: imgSrc, alt: imgAlt });
            $("#imageModal").modal("show");
        });

        const ST_VERILDI = @((int)EnumStatusType.Kargoda);
        const ST_IPTALEDILDI = @((int)EnumStatusType.İptal);

        function syncRequired() {
            const st = parseInt($("#status").val() || 0, 10);
            const need = (st === ST_VERILDI);
            const needCancel = (st === ST_IPTALEDILDI);

            $("#cargoExtraFields").toggleClass("d-none", !need);
            $("#trackingNumber").prop("required", need);
            $("#cargoCompany").prop("required", need);

            if (!need) {
                $("#trackingNumber").val("");
                $("#cargoCompany").val("");
            }

             // İptal sebebi alanı
            $("#cancelReasonField").toggleClass("d-none", !needCancel);
            $("#cancelReason").prop("required", needCancel);

            if (!needCancel) {
                $("#cancelReason").val("");
            }
        }

        $("#status").on("change", syncRequired);

        // Modal açma: satırdan bilgileri özet alanına bas
        $(document).on("click", ".change-status-btn", function () {
            const d = $(this).data();


            $("#summaryLocation").text(d.location || "-");
            $("#summaryCategory").text(d.category || "-");
            $("#summaryProduct").text(d.product || "-");
            $("#summaryQuantity").text(d.quantity || "-");
            $("#summaryRecipient").text(d.receiver || "-");
            $("#summaryAddress").text(d.address || "-");


            $("#cargoDetailId").val(d.cargodetailId || "");

            // reset
            $("#status").val("");
            $("#trackingNumber").val("");
            $("#cargoCompany").val("");

            syncRequired();
        });


        // Silme işlem
        $('.delete-cargo-btn').on('click', function(e) {
            e.preventDefault();

            var url = $(this).data('url');
            var receiver = $(this).data('receiver');

            Swal.fire({
                title: 'Emin misiniz?',
                text: receiver + " adlı alıcıya ait kargo silinecek!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Evet, sil!',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: url,
                        type: 'POST',
                        dataType: 'json', 
                        success: function(response) {
                            if (response.success) {
                                Swal.fire({
                                    title: 'Silindi!',
                                    text: receiver + " adlı alıcının kargosu silindi.",
                                    icon: 'success',
                                    showConfirmButton: false,
                                    timer: 2000
                                });

                                setTimeout(function() {
                                    location.reload();
                                }, 2000);
                            } else {
                                Swal.fire({
                                    title: 'Hata!',
                                    text: response.message,
                                    icon: 'error'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                title: 'Hata!',
                                text: 'Sunucu ile iletişim kurulamadı.',
                                icon: 'error'
                            });
                        }
                    });
                }
            });
        });

    </script>
}
