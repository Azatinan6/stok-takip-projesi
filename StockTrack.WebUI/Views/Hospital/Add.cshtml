@model StockTrack.Dto.Hospital.HospitalAddDto

@{
    ViewData["Title"] = "Yeni Hastane Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header text-white">
        <h4 class="mb-0">🏥 Yeni Hastane Ekle</h4>
    </div>
    <div class="card-body">
        <form asp-action="Add" method="post">

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 border-end pe-4">
                    <h5 class="text-primary mb-3">Genel Bilgiler</h5>

                    <div class="mb-3">
                        <label class="fw-bold">Hastane Adı</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Şube / Bölüm</label>
                        <input asp-for="Branch" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Şehir</label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Telefon</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Web Site</label>
                            <input asp-for="WebSite" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Adres</label>
                        <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="col-md-6 bg-light p-4 rounded">
                    <h5 class="text-danger mb-3">🛠️ Teknik & Entegrasyon</h5>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-secondary">HBYS Yazılımı</label>
                            <input asp-for="HbysName" class="form-control" placeholder="Örn: Fonet" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-secondary">Versiyon</label>
                            <input asp-for="HbysVersion" class="form-control" placeholder="v2.0" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold text-secondary">Kurulum Tarihi</label>
                        <input asp-for="InstallationDate" type="date" class="form-control" />
                    </div>

                    <hr class="text-muted opacity-25" />

                    <h6 class="fw-bold text-dark mb-3">HBYS Bağlantı Bilgileri</h6>
                    <div class="mb-3">
                        <label class="text-secondary">Entegrasyon URL</label>
                        <input asp-for="IntegrationUrl" type="url" class="form-control" placeholder="http://..." />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-secondary">Kullanıcı Adı</label>
                            <input asp-for="IntegrationUsername" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-secondary">Şifre</label>
                            <input asp-for="IntegrationPassword" type="password" class="form-control" />
                        </div>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <h6 class="fw-bold text-dark mb-3">Sağlık.Net (SN) Bilgileri</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-secondary">SN Kullanıcı Adı</label>
                            <input asp-for="SnUsername" class="form-control" placeholder="Kurum/SN Kodu" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-secondary">SN Şifre</label>
                            <input asp-for="SnPassword" type="password" class="form-control" />
                        </div>
                    </div>

                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between align-items-center mt-3">
                <a asp-controller="Hospital" asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="mdi mdi-arrow-left me-1"></i> Listeye Dön
                </a>
                <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">
                    <i class="mdi mdi-content-save me-1"></i> Hastaneyi Kaydet
                </button>
            </div>

        </form>
    </div>
</div>