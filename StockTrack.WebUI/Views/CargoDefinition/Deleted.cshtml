@using StockTrack.Dto.CargoDefinition
@model IEnumerable<CargoDefinitionDeletedDto>

@{
    ViewData["Title"] = "Silinen Kontrol Sonucu Tanımları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4>Silinen Kontrol Sonucu</h4>
<hr />

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>#Id</th>
            <th>Kontrol Sonucu Adı</th>
            <th>Silinme Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @{ int count = 1; }
        @foreach (var item in Model)
        {
            <tr>
                <td>@(count++)</td>
                <td>@item.Name</td>
                <td>@item.DeletedDate?.ToString("dd MMMM yyyy HH:mm")</td>
                <td>
                    <form asp-controller="CargoDefinition" asp-action="Restore" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu tanımı geri yüklemek istediğinize emin misiniz?');">
                        <button type="submit" class="btn btn-success btn-sm">
                            <i class="mdi mdi-restore me-1"></i> Geri Yükle
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="CargoDefinition" asp-action="Index" class="btn btn-secondary">
        <i class="fa fa-arrow-left"></i>Kargo Kontrol Sonucu Listesine Dön
    </a>
</div>
