@model IEnumerable<StockTrack.Entity.Enitities.ProductSet>
@{
    ViewData["Title"] = "Setler Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 text-dark"><i class="mdi mdi-layers-triple text-primary me-2"></i> Set Tanımları</h5>
        <a href="~/Set/Create" class="btn btn-primary shadow-sm">
            <i class="mdi mdi-plus"></i> Yeni Set Ekle
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th width="10%">#ID</th>
                        <th width="40%">Set Adı</th>
                        <th width="15%">İçerik Sayısı</th>
                        <th width="15%">Durum</th>
                        <th width="20%" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-muted">@item.Id</td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @(item.ProductSetItems?.Count ?? 0) Ürün
                                    </span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Pasif</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="~/Set/Edit/@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <a href="~/Set/ToggleStatus/@item.Id" class="btn btn-sm btn-outline-warning" title="Aktif/Pasif Yap">
                                            <i class="mdi mdi-swap-horizontal"></i>
                                        </a>
                                        <a href="~/Set/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="Sil" onclick="return confirm('Bu seti silmek istediğinize emin misiniz?');">
                                            <i class="mdi mdi-trash-can"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Henüz bir set oluşturulmamış.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>