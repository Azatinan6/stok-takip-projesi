@using StockTrack.Dto.Inventory
@model IEnumerable<InventoryListDto>

@{
    ViewData["Title"] = "Güncel Stok Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<div class="d-flex justify-content-between alig-items-center ">
    <h4 class="mb-3">Güncel Stok Durumu</h4>
    <div>
        <a href="~/Inventory/Deleted" class="btn btn-outline-danger me-2 shadow-sm">
            <i class="mdi mdi-delete-restore me-1"></i> Silinenler
        </a>
        <a href="~/Inventory/AddProduct" class="btn btn-primary shadow-sm">
            <i class="mdi mdi-plus"></i> Yeni Ürün Girişi
        </a>
    </div>
</div>

<hr>

    <div class="card-body">
        <div class="table-responsive">
        <table id="DataTables" class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                    <tr>
                        <th>ID</th>
                        
                        <th>Depo Adı</th>
                        <th>Kategori</th>
                        <th>Marka</th>
                        <th>Model</th>
                        <th>Ürün Adı</th>
                        <th>Görsel</th>
                        <th>Güncel Stok Adeti</th>
                        <th>Stok Uyarı Seviyesi</th>
                        <th>Aktif mi ?</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <span class="badge bg-dark-subtle text-dark">@item.WarehouseName</span>
                                </td>
                                <td>@item.CategoryName</td>
                                <td>@item.Brand</td>
                                <td>@item.Model</td>
                                <td class="fw-bold text-dark">@item.ProductName</td>
                                <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                    <a href="@item.ImageUrl" target="_blank" class="btn btn-sm btn-light border shadow-sm" title="Görseli büyük aç">
                                        <i class="mdi mdi-image-outline text-info fs-5"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-light border opacity-50" title="Görsel Yüklenmemiş" disabled>
                                        <i class="mdi mdi-image-off-outline text-muted fs-5"></i>
                                    </button>
                                }

                                </td>
                                <td>
                                    @if (item.StockQuantity <= item.StockWarningLevel)
                                    {
                                        <span class="badge bg-danger fs-6" title="Kritik Seviye!">@item.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success fs-6">@item.StockQuantity</span>
                                    }
                                </td>
                                <td>
                                <span class="badge bg-success fs-6">@item.StockWarningLevel</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Pasif</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="~/Inventory/Detail/@item.Id" class="btn btn-sm btn-info text-white" title="Detay (Stok, Giriş, Çıkış)">
                                            <i class="mdi mdi-eye"></i> Detay
                                        </a>
                                        <a href="~/Inventory/Edit/@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                            <i class="mdi mdi-pencil"></i>
                                        </a>
                                        <a href="~/Inventory/ToggleStatus/@item.Id" class="btn btn-sm btn-outline-warning" title="Aktif/Pasif Yap">
                                            <i class="mdi mdi-swap-horizontal"></i>
                                        </a>
                                        <a href="~/Inventory/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="Sil" onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                            <i class="mdi mdi-trash-can"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
