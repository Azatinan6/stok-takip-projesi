@using StockTrack.Dto.CargoDetail
@model List<ResultCargoInDeliveryDto>

@{
    ViewData["Title"] = "Kargoda Olanlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex flex-wrap gap-3 mb-4">

    <!-- Tümü -->
    <a href="~/CargoDetail/Index"
           class="btn rounded-pill px-4 shadow-sm border"
           style="background-color: #f1f3f5; color: #495057;">
        Tümü (@ViewBag.AllCount)
    </a>

    <!-- Onay Bekliyor -->
    <a href="~/CargoDetail/AwaitingApproval"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #fde2e1; color: #d62828; border: 1px solid #f5c2c0;">
        Onay Bekliyor (@ViewBag.PendingCount)
    </a>

    <!-- Paketlendi -->
    <a href="~/CargoDetail/ReadyForCargo"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #fff4cc; color: #e0a800; border: 1px solid #ffe69c;">
        Paketlendi (@ViewBag.PackagedCount)
    </a>

    <!-- Kargoda -->
    <a href="~/CargoDetail/CargoInDelivery"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #d0ebff; color: #1971c2; border: 1px solid #a5d8ff;">
        Kargoda (@ViewBag.InCargoCount)
    </a>

    <!-- Teslim Edildi -->
    <a href="~/CargoDetail/Delivered"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #d3f9d8; color: #2b8a3e; border: 1px solid #b2f2bb;">
        Teslim Edildi (@ViewBag.DeliveredCount)
    </a>

    <!-- İptal -->
    <a href="~/CargoDetail/Cancelled"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #ffe3e3; color: #c92a2a; border: 1px solid #ffc9c9;">
        İptal Edilenler (@ViewBag.CancelledCount)
    </a>

    <!-- Silinen -->
    <a href="~/CargoDetail/Deleted"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #e9ecef; color: #6c757d; border: 1px solid #dee2e6;">
        Silinenler (@ViewBag.DeletedCount)
    </a>

</div>

<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
    <h4>Kargoda Transferinde Olan Ürünler</h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>ID</th> <!-- PDF: ID -->
            <th>Durum</th> <!-- PDF: Durum -->
            <th>Tarih</th> <!-- PDF: Tarih -->
            <th>Kullanıcı</th> <!-- PDF: Kullanıcı -->
            <th>Depo</th> <!-- PDF: Depo -->
            <th>Ürün (Kategori : Miktar)</th> <!-- PDF: Ürün -->
            <th>Lokasyon</th> <!-- PDF: Lokasyon -->
            <th>Kargo Verilme Tarihi</th> <!-- PDF: Yeni Kolon -->
            <th>Kargo Takip No</th> <!-- PDF: Kritik Zeka Kolonu -->
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <span class="badge @(item.StatusId == 4 ? "bg-info" : "bg-primary")">
                        @item.StatusName
                    </span>
                </td>
                <td>@item.RequestFormDate.ToString("dd.MM.yyyy")</td>
                <td>@(item.RequestFormBy ?? "-")</td>
                <td>@item.MainRepoName</td>
                <td>
                    <!-- PDF Formatı: Kategori : Miktar -->
                    @foreach (var p in item.Products)
                    {
                        <div>@p.CategoryName : @p.Quantity Adet</div>
                    }
                </td>
                <td>@item.HospitalName</td>
                
                <!-- Kargo Verilme Tarihi -->
                <td>@(item.CargoGivenDate?.ToString("dd.MM.yyyy") ?? "-")</td>

                <!-- TAKİP NO ZEKASI -->
                <td>
                    @if (item.IsOfficeDelivery && (item.StatusId == (int)EnumStatusType.Kargoda || item.StatusId == (int)EnumStatusType.Tamamlandı))
                    {
                        <!-- PDF Kuralı: Ofisten teslimse ve süreç tamamlanmışsa bu yazacak -->
                        <span class="badge bg-secondary">Ofisten Teslim Edildi</span>
                    }
                    else if (string.IsNullOrEmpty(item.TrackingNumber) && (item.StatusId == (int)EnumStatusType.Kargoda || item.StatusId == (int)EnumStatusType.Tamamlandı))
                    {
                        <!-- PDF Kuralı: Kargoya verildi/Teslim edildi ama numara yoksa kırmızı fontla uyar -->
                        <span class="text-danger fw-bold">Takip No Giriniz !</span>
                    }
                    else
                    {
                        <!-- Normal şartlarda takip numarasını yaz -->
                        @(string.IsNullOrEmpty(item.TrackingNumber) ? "-" : item.TrackingNumber)
                    }
                </td>

                <td>
                    <button type="button" class="btn btn-sm btn-primary change-status-btn" style="white-space:nowrap !important;"
                            data-bs-toggle="modal" data-bs-target="#cargoStatusModal"
                            data-cargodetailid="@item.Id"
                            data-location="@item.HospitalName"
                            data-category="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.CategoryName)) : "-")"
                            data-product="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.ProductName)) : "-")"
                            data-quantity="@(item.Products.Any() ? string.Join(", ", item.Products.Select(p => p.Quantity)) : "-")"
                            data-receiver="@item.ReceiverFullName"
                            data-address="@item.HospitalAddress"
                            data-tracking="@item.TrackingNumber" 
                            data-company="@item.CargoNameId">
                        <i class="mdi mdi-cog"></i> İşlem Yap
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Resim önizleme -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid rounded" style="max-height:70vh;">
            </div>
        </div>
    </div>
</div>

<!-- Kargo Durumu Modal -->
<div class="modal fade" id="cargoStatusModal" tabindex="-1" aria-labelledby="cargoStatusLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <form asp-action="SaveCargoInfo" id="cargoOperasyonForm" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="cargoDetailId" />

                <div class="modal-header bg-light">
                    <h5 class="modal-title" id="cargoStatusLabel">Kargo Bilgileri ve Durum Güncelle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="row">
                        <!-- ================= SOL TARAF: GÖNDERİM DETAYI (BİLGİ EKRANI) ================= -->
                        <div class="col-lg-6 border-end pe-4">
                            <h6 class="text-uppercase text-muted mb-3 border-bottom pb-2">1. GÖNDERİM DETAYI</h6>

                            <table class="table table-sm table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="text-muted" style="width: 140px;">Lokasyon:</td>
                                        <td class="fw-bold" id="summaryLocation">-</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Kategori:</td>
                                        <td class="fw-bold" id="summaryCategory">-</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Ürün Adı:</td>
                                        <td class="fw-bold">
                                            <span id="summaryProduct">-</span>
                                            
                                            <!-- ARC BOX ZEKASI: Ürün Arc Box ise bu ikon görünür olacak -->
                                            <a href="javascript:void(0);" id="arcBoxConfigIcon" class="text-warning ms-2 d-none"
                                                   data-bs-toggle="popover" title="Arc Box Config İçeriği"
                                                   data-bs-content="Seri No: Bekleniyor... | ETH MAC: ... | WLAN MAC: ... | Bağlantı Türü: ... | config_url | dhcpd.conf | wpa_supplicant.conf">
                                                <i class="mdi mdi-cog fs-5 spin-icon" title="Config Detayları"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Adet:</td>
                                        <td class="fw-bold" id="summaryQuantity">-</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Alıcı:</td>
                                        <td class="fw-bold" id="summaryRecipient">-</td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Adres:</td>
                                        <td class="fw-bold small text-wrap" id="summaryAddress">-</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- ================= SAĞ TARAF: KARGO DURUM GÜNCELLE (İŞLEM EKRANI) ================= -->
                        <div class="col-lg-6 ps-4">
                            <h6 class="text-uppercase text-muted mb-3 border-bottom pb-2">2. Kargo Durum Güncelle</h6>
                            <!-- Kargo Durumu -->
                            <div class="d-flex flex-column mb-3">
                                <label class="col-form-label fw-bold">Durumu <span class="text-danger">*</span></label>
                                <div class="ms-0">
                                    <select name="StatusId"
                                    id="cargoStatusSelect"
                                    class="form-select
                                    border-primary">
                                        <option value="">-- Durum Seçiniz --</option>
                                        <option value="@((int)EnumStatusType.Kargoda)">Takip No / Firma Güncelle</option>
                                        <option value="@((int)EnumStatusType.Tamamlandı)">Teslim Edildi</option>
                                        <option value="@((int)EnumStatusType.İptal)">İptal Edildi</option>
                                    </select> 
                                </div>
                            </div>

                            <!-- Kargo Firması ve Takip No -->
                            <div id="cargoExtraFields" class="row g-3 d-none bg-light p-2 rounded border mt-1">
                                <div class="col-12">
                                    <label class="form-label mb-1">Kargo Firması <span class="text-danger">*</span></label>
                                    <select name="CargoNameId" id="cargoCompany" class="form-select w-100" asp-items="@(ViewBag.CargoNames)">
                                        <option value="">-- Seçiniz --</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label mb-1">Kargo Takip Numarası <span class="text-danger">*</span></label>
                                    <input type="text" name="TrackingNumber" id="trackingNumber" class="form-control w-100" placeholder="Örn: 1Z9999999999999999" />
                                </div>
                            </div>
                            <!-- İptal Sebebi -->
                            <div id="cancelReasonField" class="row mt-3 d-none">
                                <div class="col-12">
                                    <label class="form-label text-danger fw-bold mb-1">İptal Sebebi <span class="text-danger">*</span></label>
                                    <textarea name="CancelDescription" id="cancelReason" class="form-control border-danger w-100" rows="2" placeholder="Neden iptal edildiğini yazın..."></textarea>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                

                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>                    
                    <button type="button" id="btnSaveCargo" class="btn btn-success px-5"><i class="mdi mdi-content-save-check"></i> Kaydet ve Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>



<!-- Resim Önizleme Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="" class="img-fluid rounded" style="max-height:70vh;">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Resim önizleme
        $(document).on("click", ".preview-img", function () {
            const imgSrc = $(this).data("img");
            const imgAlt = $(this).data("alt") || "";
            $("#modalImage").attr({ src: imgSrc, alt: imgAlt });
            $("#imageModal").modal("show");
        });

        const ST_VERILDI     = @((int)EnumStatusType.Kargoda);
        const ST_IPTALEDILDI = @((int)EnumStatusType.İptal);

        // HAFIZA KUTULARI (Robotun eski numaraları unutmaması için)
        let tempTracking = "";
        let tempCompany = "";

        // Vitrin düzenleyici robot
        function syncRequired() {
            const st = parseInt($("#cargoStatusSelect").val() || 0, 10);

            const needCargo  = (st === ST_VERILDI);
            const needCancel = (st === ST_IPTALEDILDI);

            // Kargo kutularını aç/kapat
            $("#cargoExtraFields").toggleClass("d-none", !needCargo);
            
            // İŞTE SENİN ZEKAN BURADA DEVREYE GİRİYOR
            if (needCargo) {
                // Eğer Güncelle'yi seçtiyse, hafızadaki eski numaraları kutuya bas!
                $("#trackingNumber").val(tempTracking);
                $("#cargoCompany").val(tempCompany);
            } else {
                // Seçmediyse kutuları temizle
                $("#trackingNumber").val("");
                $("#cargoCompany").val("");
            }

            $("#cancelReasonField").toggleClass("d-none", !needCancel);
            if (!needCancel) {
                $("#cancelReason").val("");
            }
        }

        $("#cargoStatusSelect").on("change", syncRequired);

        // Güvenlik görevlisi robot (Kaydetme Kontrolü)
        $("#btnSaveCargo").on("click", function () {
            const st = parseInt($("#cargoStatusSelect").val() || 0, 10);
            const tracking = $("#trackingNumber").val().trim();
            const company = $("#cargoCompany").val();
            const cancelReason = $("#cancelReason").val().trim();

            if (st === 0 || isNaN(st)) {
                Swal.fire('Eksik Bilgi', 'Lütfen Kargo Durumunu seçiniz.', 'warning');
                return;
            }
            if (st === ST_VERILDI && (!company || !tracking)) {
                Swal.fire('Eksik Bilgi', 'Kargoya verildi durumunda Kargo Firması ve Takip Numarası zorunludur!', 'warning');
                return;
            }
            if (st === ST_IPTALEDILDI && !cancelReason) {
                Swal.fire('Eksik Bilgi', 'İptal durumunda İptal Sebebi zorunludur!', 'warning');
                return;
            }

            $("#cargoOperasyonForm")[0].submit();
        });

        // Tepsiyi dolduran garson (Modal Açma)
        $(document).on("click", ".change-status-btn", function () {
            const d = $(this).data();

            // 1. O anki kargonun eski bilgilerini HAFIZAYA AL!
            tempTracking = d.tracking || "";
            tempCompany = d.company ? d.company.toString() : "";

            // 2. Sol tarafı doldur
            $("#cargoDetailId").val(d.cargodetailid || "");
            $("#summaryLocation").text(d.location || "-");
            $("#summaryCategory").text(d.category || "-");
            $("#summaryQuantity").text(d.quantity || "-");
            $("#summaryRecipient").text(d.receiver || "-");
            $("#summaryAddress").text(d.address || "-");
    
            let productName = d.product || "-";
            $("#summaryProduct").text(productName);

            // ARC BOX ZEKASI
            if (productName.toLowerCase().includes("arc box")) {
                $("#arcBoxConfigIcon").removeClass("d-none");
                var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'))
                var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
                    return new bootstrap.Popover(popoverTriggerEl)
                });
            } else {
                $("#arcBoxConfigIcon").addClass("d-none");
            }

            // Formu sıfırla ve kutuları gizle
            $("#cargoStatusSelect").val("").trigger("change");
        });
    </script>
}