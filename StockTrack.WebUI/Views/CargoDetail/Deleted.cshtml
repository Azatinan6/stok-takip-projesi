@using StockTrack.Dto.CargoDetail
@model List<ResultCargoDeletedDto>

@{
    ViewData["Title"] = "Silinen Kargolar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Üst Sekmeler (Aynı Kalıyor) -->
<div class="d-flex flex-wrap gap-3 mb-4">
    <a href="~/CargoDetail/Index" class="btn rounded-pill px-4 shadow-sm border" style="background-color: #f1f3f5; color: #495057;">Tümü (@ViewBag.AllCount)</a>
    <a href="~/CargoDetail/AwaitingApproval" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fde2e1; color: #d62828; border: 1px solid #f5c2c0;">Onay Bekliyor (@ViewBag.PendingCount)</a>
    <a href="~/CargoDetail/ReadyForCargo" class="btn rounded-pill px-4 shadow-sm" style="background-color: #fff4cc; color: #e0a800; border: 1px solid #ffe69c;">Paketlendi (@ViewBag.PackagedCount)</a>
    <a href="~/CargoDetail/CargoInDelivery" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d0ebff; color: #1971c2; border: 1px solid #a5d8ff;">Kargoda (@ViewBag.InCargoCount)</a>
    <a href="~/CargoDetail/Delivered" class="btn rounded-pill px-4 shadow-sm" style="background-color: #d3f9d8; color: #2b8a3e; border: 1px solid #b2f2bb;">Teslim Edildi (@ViewBag.DeliveredCount)</a>
    <a href="~/CargoDetail/Cancelled" class="btn rounded-pill px-4 shadow-sm" style="background-color: #ffe3e3; color: #c92a2a; border: 1px solid #ffc9c9;">İptal Edilenler (@ViewBag.CancelledCount)</a>
    <a href="~/CargoDetail/Deleted" class="btn rounded-pill px-4 shadow-sm" style="background-color: #e9ecef; color: #6c757d; border: 1px solid #dee2e6;">Silinenler (@ViewBag.DeletedCount)</a>
</div>

<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
    <h4><i class="mdi mdi-delete-variant text-secondary"></i> Silinen Kargo Kayıtları</h4>
</div>
<hr />

<table id="DataTables" class="table table-hover align-middle mb-0" style="width:100%">
    <thead>
        <tr>
            <th>ID</th>
            <th>Durum</th>
            <th>Silinme Tarihi</th>
            <th>Silen Kişi</th>
            <th>Ürünler</th>
            <th>Lokasyon</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td><span class="badge bg-secondary">@item.StatusName</span></td>
                <td>@(item.DeletedDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                <td>@(item.DeletedBy ?? "Sistem")</td>
                <td>
                    @foreach (var p in item.Products)
                    {
                        <div class="small">@p.CategoryName : @p.Quantity Adet</div>
                    }
                </td>
                <td>@item.HospitalName</td>
                <td>
                    <button type="button" class="btn btn-sm btn-dark deleted-detail-btn"
                            data-bs-toggle="modal" data-bs-target="#deletedDetailModal"
                            data-id="@item.Id"
                            @* DTO isimlerine dikkat: *@
                            data-by="@item.DeletedBy"
                            data-date="@item.DeletedDate?.ToString("dd.MM.yyyy HH:mm")"
                            data-reqby="@item.RequestFormBy"
                            data-reqdate="@item.RequestFormDate.ToString("dd.MM.yyyy")"
                            data-receiver="@item.ReceiverFullName"
                            data-location="@item.HospitalName">
                        <i class="mdi mdi-eye-outline"></i> Detay
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Silme Detayı Modalı -->
<div class="modal fade" id="deletedDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-top border-secondary border-4">
            <div class="modal-header bg-light">
                <h5 class="modal-title text-secondary"><i class="mdi mdi-delete-restore"></i> Silinmiş Kayıt Bilgisi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-4">
                <div class="alert alert-secondary border-0 mb-4 text-center">
                    <strong>ID: #<span id="detId"></span></strong> numaralı kargo kaydı silinmiştir.
                </div>
                
                <div class="row g-3">
                    <div class="col-6">
                        <label class="text-muted small d-block">Silen Kullanıcı:</label>
                        <span class="fw-bold" id="detBy">-</span>
                    </div>
                    <div class="col-6 text-end">
                        <label class="text-muted small d-block">Silinme Tarihi:</label>
                        <span class="fw-bold" id="detDate">-</span>
                    </div>
                    <div class="col-12"><hr class="my-1"></div>
                    <div class="col-6">
                        <label class="text-muted small d-block">Talebi Açan:</label>
                        <span class="fw-bold" id="detReqBy">-</span>
                    </div>
                    <div class="col-6 text-end">
                        <label class="text-muted small d-block">Talep Tarihi:</label>
                        <span class="fw-bold" id="detReqDate">-</span>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small d-block">Alıcı / Lokasyon:</label>
                        <span class="fw-bold" id="detLocation">-</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on("click", ".deleted-detail-btn", function () {
            const d = $(this).data();
            $("#detId").text(d.id);
            $("#detBy").text(d.by || "Bilinmiyor");
            $("#detDate").text(d.date || "-");
            $("#detReqBy").text(d.reqby || "-");
            $("#detReqDate").text(d.reqdate || "-");
            $("#detLocation").text((d.receiver || "") + " / " + (d.location || ""));
        });
    </script>
}